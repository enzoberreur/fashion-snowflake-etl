# Monogram Paris - environment template. Copy to .env and fill in real values.
# .env is gitignored; never commit real credentials.

# --- Snowflake (key-pair auth) ---
SNOWFLAKE_ACCOUNT=your_org-your_account
SNOWFLAKE_USER=YOUR_USER
SNOWFLAKE_ROLE=INGEST
SNOWFLAKE_WAREHOUSE=INGEST
SNOWFLAKE_DATABASE=INGEST
SNOWFLAKE_SCHEMA=INGEST
# Preferred: path to the unencrypted PKCS8 private key
SNOWFLAKE_PRIVATE_KEY_PATH=keys/rsa_key.p8
# Alternative: paste the raw PEM (and a passphrase if the key is encrypted)
# PRIVATE_KEY=
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# --- Real-time streaming (Kafka / Redpanda + Snowpipe Streaming) ---
# Use localhost:19092 from the host; redpanda:9092 inside the compose network
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_SALES_TOPIC=monogram.sales.stream
KAFKA_CONSUMER_GROUP=monogram-stream-consumer
STREAM_TABLE=STREAM_SALES
STREAM_CHANNEL_PREFIX=monogram

# --- Optional: failure alerting (Airflow callbacks) ---
# SLACK_WEBHOOK_URL=
