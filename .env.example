# Snowflake connection — copy to .env and fill in
# .env is gitignored. NEVER commit real credentials.

SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_username
SNOWFLAKE_WAREHOUSE=INGEST
SNOWFLAKE_DATABASE=INGEST
SNOWFLAKE_SCHEMA=INGEST
SNOWFLAKE_ROLE=INGEST

# Key-pair authentication (recommended)
# Option A: path to PEM file on disk
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_passphrase

# Option B: raw PEM content as a single env var (overrides PATH)
# PRIVATE_KEY="-----BEGIN ENCRYPTED PRIVATE KEY-----\n...\n-----END ENCRYPTED PRIVATE KEY-----"
